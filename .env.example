# === Model providers (Phase 0: pick baseline + candidate by which keys exist) ===
OPENAI_API_KEY=                    # baseline and/or candidate (gpt-4o-mini / gpt-4o)
ANTHROPIC_API_KEY=                 # optional second provider (haiku / sonnet)
ARCNET_MODEL=gpt-4o-mini           # baseline model id — drives pricing.py lookup
ARCNET_CANDIDATE_MODEL=gpt-4o      # Time Machine candidate model id

# === Telemetry → SigNoz ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318   # OTLP HTTP (collector)
SIGNOZ_URL=http://localhost:8080                    # SigNoz UI + Query Range API
SIGNOZ_API_KEY=                                     # service-account key (server-side only; create in UI)
# Optional dashboard UUID overrides (else /api/signoz/status resolves by title after provision)
SIGNOZ_DASHBOARD_FLEET=
SIGNOZ_DASHBOARD_THREATS=
SIGNOZ_DASHBOARD_COST=
SIGNOZ_DASHBOARD_AGNO=

# === ArcNet server / UI ===
ARCNET_SERVER_URL=http://localhost:8000             # signal SSE + API base (sdk/, hq/)
ARCNET_AGENTOS_URL=http://localhost:7777             # internal replay adapter hosted by the agent runtime

# === Optional ===
HF_TOKEN=                                           # only if TabFM/TabPFN weight download needs it
TABPFN_TOKEN=                                       # Prior Labs token; Griffin falls back to MAD when absent

# === Local-dev write / webhook abuse controls (optional; empty = localhost-trust) ===
# ARCNET_WRITE_SECRET=                              # when set: X-ArcNet-Write-Secret or Bearer on POST /api/signal, sessions, threats, sources, agents, versions
# ARCNET_WEBHOOK_SECRET=                            # when set: X-ArcNet-Webhook-Secret or Bearer on POST /webhooks/signoz
