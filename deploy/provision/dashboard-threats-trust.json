      "query": {
        "queryType": "clickhouse_sql",
        "unit": "",
        "id": "f0f3747f-ee78-4efd-b3d8-6eb0c82ee2fd",
        "builder": {
          "queryData": [],
          "queryFormulas": [],
          "queryTraceOperator": []
        },
        "clickhouse_sql": [
          {
            "disabled": false,
            "legend": "findings",
            "name": "A",
            "query": "SELECT\n  attributes_string['arcnet.guard.top_category'] AS category,\n  attributes_string['arcnet.guard.action'] AS action,\n  count() AS c\nFROM signoz_traces.distributed_signoz_index_v2\nWHERE name = 'arcnet.guard'\n  AND timestamp >= now() - INTERVAL 24 HOUR\nGROUP BY category, action\nORDER BY c DESC\nLIMIT 20"
          }
        ],
        "promql": [
